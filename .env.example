# ============================================================
# cancer-pipeline — Environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── PostgreSQL connection ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cancer_pipeline
POSTGRES_USER=cancer_user
POSTGRES_PASSWORD=your_secure_password_here

# ── Kaggle API credentials ───────────────────────────────────
# Get these from https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Kaggle dataset identifier (owner/dataset-slug)
KAGGLE_DATASET=ritheshsreenivasan/clinical-text-classification

# ── Airflow ─────────────────────────────────────────────────
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://cancer_user:your_secure_password_here@localhost:5432/cancer_pipeline

# ── Model ───────────────────────────────────────────────────
# Path to the saved Bi-LSTM Keras model (.h5 or SavedModel dir)
MODEL_PATH=./models/bilstm_cancer_classifier.h5
# Path to the fitted tokenizer (pickle or JSON)
TOKENIZER_PATH=./models/tokenizer.pkl
# Maximum sequence length used during training
MAX_SEQUENCE_LENGTH=500

# ── Streamlit ───────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ============================================================
# AWS CLOUD SETTINGS (optional — leave blank for local-only mode)
# The pipeline runs fully locally without these.
# Fill them in to enable S3 storage and RDS PostgreSQL.
# ============================================================

# ── AWS credentials ──────────────────────────────────────────
# For local development only. In production (EC2/ECS/MWAA),
# use an IAM Role instead — never hard-code keys on a server.
# Get these from: AWS Console → IAM → Users → Security credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ── S3 bucket ────────────────────────────────────────────────
# Create the bucket first: aws s3 mb s3://your-bucket-name
# Naming rules: lowercase, no underscores, globally unique
S3_BUCKET=your-cancer-pipeline-bucket

# S3 key prefixes (folder paths inside the bucket)
S3_RAW_PREFIX=data/raw/
S3_PROCESSED_PREFIX=data/processed/
S3_MODEL_PREFIX=models/

# ── RDS PostgreSQL ───────────────────────────────────────────
# Leave blank to use the local Docker PostgreSQL.
# Set to your RDS endpoint to use cloud-managed PostgreSQL.
# Find this in: AWS Console → RDS → Databases → your-db → Endpoint
RDS_HOST=
# RDS_HOST=mydb.xxxx.us-east-1.rds.amazonaws.com
RDS_PORT=5432
