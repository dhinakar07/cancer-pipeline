# ── Secrets — NEVER commit these ────────────────────────────
.env
*.pem
*.key

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Data (too large for git) ─────────────────────────────────
data/raw/*.csv
data/processed/*.csv

# ── Trained model artefacts (use S3 instead) ────────────────
models/*.h5
models/*.pkl
models/*.pt

# ── Airflow generated files ──────────────────────────────────
airflow/logs/
airflow/airflow.db
airflow/airflow.cfg

# ── OS & editor ──────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ── Test coverage ────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
